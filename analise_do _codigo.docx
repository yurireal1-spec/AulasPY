6. EXEMPLOS PRÁTICOS DE CADA ESTRUTURA
================================================================================

【 EXEMPLO 1 - Variável simples 】
    score = 0
    score += 10

【 EXEMPLO 2 - Dicionário 】
    player = {"x": 400, "y": 250, "radius": 18}
    player["x"] = new_x

【 EXEMPLO 3 - Lista 】
    stars = []
    stars.append(create_star())
    stars.remove(star)

【 EXEMPLO 4 - List Comprehension 】
    [(i*131)%WIDTH for i in range(100)]

【 EXEMPLO 5 - Decisão IF 】
    if game_over:
        return

【 EXEMPLO 6 - Decisão com comparação encadeada 】
    if 0 < new_x - player["radius"] < WIDTH:
        player["x"] = new_x

【 EXEMPLO 7 - Loop FOR range 】
    for _ in range(NUM_STARS):
        stars.append(create_star())

【 EXEMPLO 8 - Loop FOR com cópia 】
    for star in stars[:]:
        stars.remove(star)

【 EXEMPLO 9 - Loop FOR com desempacotamento 】
    for x, y in background_stars:
        ctx.arc(x, y, 1, 0, 2*math.pi)

【 EXEMPLO 10 - Loop WHILE 】
    while len(stars) < NUM_STARS:
        stars.append(create_star())

【 EXEMPLO 11 - Recursão 】
    def game_loop():
        update()
        timer.set_timeout(game_loop, 16)

